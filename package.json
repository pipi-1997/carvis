{
  "name": "carvis",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "./scripts/run-with-runtime-env.sh bun run --filter @carvis/gateway dev",
    "dev:executor": "./scripts/run-with-runtime-env.sh bun run --filter @carvis/executor dev",
    "start:gateway": "./scripts/run-with-runtime-env.sh bun run --filter @carvis/gateway dev",
    "start:executor": "./scripts/run-with-runtime-env.sh bun run --filter @carvis/executor dev",
    "test:003": "bun test tests/unit/presentation-setup.test.ts tests/unit/runtime-harness.test.ts",
    "test:memory-benchmark": "bun test tests/contract/memory-benchmark-runner.contract.test.ts tests/contract/memory-benchmark-gate.contract.test.ts tests/integration/memory-benchmark.test.ts tests/integration/memory-benchmark-golden-scenarios.test.ts tests/integration/memory-benchmark-suite-coverage.test.ts tests/integration/memory-benchmark-gate.test.ts",
    "test:memory-benchmark:gate": "bun run test:memory-benchmark",
    "test:unit": "bun test tests/unit",
    "lint": "bunx tsc --noEmit",
    "test": "bun test",
    "check:publish-deps": "node ./scripts/check-publish-runtime-deps.mjs",
    "publish:npm": "bash ./scripts/publish-npm.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "hono": "^4.7.2",
    "pg": "^8.16.3",
    "redis": "^5.8.2",
    "zod": "^4.1.8"
  }
}
