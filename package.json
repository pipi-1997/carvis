{
  "name": "carvis",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "bun run --filter @carvis/gateway dev",
    "dev:executor": "bun run --filter @carvis/executor dev",
    "start:gateway": "bun run --filter @carvis/gateway dev",
    "start:executor": "bun run --filter @carvis/executor dev",
    "test:003": "bun test tests/unit/presentation-setup.test.ts tests/unit/runtime-harness.test.ts",
    "test:unit": "bun test tests/unit",
    "lint": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "hono": "^4.7.2",
    "pg": "^8.16.3",
    "redis": "^5.8.2",
    "zod": "^4.1.8"
  }
}
