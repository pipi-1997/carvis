#!/bin/sh

# 解析当前脚本真实路径，兼容全局 npm symlink 安装
SCRIPT_PATH="$0"
if [ -L "$SCRIPT_PATH" ]; then
  # 跟随一次 symlink（npm 全局安装场景下通常足够）
  TARGET="$(readlink "$SCRIPT_PATH")"
  case "$TARGET" in
    /*) SCRIPT_PATH="$TARGET" ;;
    *) SCRIPT_DIR_TMP=$(CDPATH= cd -- "$(dirname "$SCRIPT_PATH")" && pwd)
       SCRIPT_PATH="$SCRIPT_DIR_TMP/$TARGET"
       ;;
  esac
fi

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$SCRIPT_PATH")" && pwd)

# 全局安装时结构通常是：
#   $PREFIX/lib/node_modules/@carvis/carvis-cli/bin/carvis
# 包根目录就是 bin 的上一级
PKG_DIR="$SCRIPT_DIR/.."

if [ ! -f "$PKG_DIR/src/bin.ts" ]; then
  echo "error: cannot locate carvis cli entry at \"$PKG_DIR/src/bin.ts\". Is @carvis/carvis-cli installed correctly?" >&2
  exit 1
fi

exec bun --bun "$PKG_DIR/src/bin.ts" "$@"
